# Environment Variables for React App
# Note: In Vite, variables must be prefixed with VITE_ to be accessible in the browser

# API Base URL
VITE_API_BASE_URL=http://localhost:3000

# App Configuration
VITE_APP_NAME=Expense Tracker
VITE_APP_VERSION=1.0.0

# Database URL (if needed in frontend)
VITE_DB_NAME=expense_tracker

# Other configuration
VITE_MAX_EXPENSE_AMOUNT=10000
VITE_DEFAULT_CURRENCY=₹
